#!/usr/bin/env bash

# ==========================================================
# Local Network Security Audit (Home Edition)
# Versión 2026
# Uso exclusivo en redes propias o autorizadas
# ==========================================================

set -Eeuo pipefail
IFS=$'\n\t'
umask 077

# ---------- COLORES ----------
export TERM=xterm-256color

BLANCO="\e[1;37m"
AZUL="\e[1;36m"
AMARILLO="\e[1;33m"
ROJO="\e[1;31m"
VERDE="\e[1;32m"
RESET="\e[0m"

# ---------- USUARIO ----------
REAL_USER=$(logname 2>/dev/null || echo "${SUDO_USER:-$USER}")
GRUPO_REAL=$(id -gn "$REAL_USER")

if command -v xdg-user-dir >/dev/null 2>&1; then
    DESKTOP_PATH=$(sudo -u "$REAL_USER" xdg-user-dir DESKTOP)
else
    DESKTOP_PATH="/home/$REAL_USER/Desktop"
    [[ ! -d "$DESKTOP_PATH" ]] && DESKTOP_PATH="/home/$REAL_USER/Escritorio"
fi

# ---------- TEMPORALES ----------
WORKDIR=$(mktemp -d /tmp/netaudit_XXXXXX)
chmod 700 "$WORKDIR"

HOSTS_FILE="$WORKDIR/hosts.txt"
RESULTS_DIR="$WORKDIR/results"

mkdir -p "$RESULTS_DIR"

# ---------- LIMPIEZA ----------
cleanup() {
    [[ -d "$WORKDIR" ]] && rm -rf "$WORKDIR"
}

trap cleanup EXIT INT TERM

# ---------- LOGO ----------
mostrar_logo() {
    clear
    echo -e "${AZUL}"
    echo "  █████  ██      ██      ██    ██ ███    ███ ███████ "
    echo " ██   ██ ██      ██      ██    ██ ████  ████ ██      "
    echo " ███████ ██      ██      ███████ ██ ████ ██ █████    "
    echo " ██   ██ ██      ██           ██ ██  ██  ██ ██      "
    echo " ██   ██ ███████ ███████      ██ ██      ██ ███████ "
    echo -e "${BLANCO}   Versión 3.5 - Auditoría Avanzada y Evasión ${RESET}"
    echo -e "${AZUL}  --------------------------------------------------${RESET}"
    echo -e "${AMARILLO}   Uso exclusivo para redes autorizadas y auditorías internas.${RESET}\n"
}

# ---------- ROOT ----------
check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${ROJO}Debe ejecutarse como root${RESET}"
        echo
        echo "sudo $0"
        exit 1
    fi
}

# ---------- DEPENDENCIAS ----------
check_tools() {
    local tools=(
        arp-scan
        nmap
        ip
        awk
        sed
        grep
        mktemp
    )

    for t in "${tools[@]}"; do
        if ! command -v "$t" >/dev/null 2>&1; then
            echo -e "${ROJO}Falta: $t${RESET}"
            exit 1
        fi
    done
}

# ---------- RED ----------
detectar_red() {
    INTERFAZ=$(ip route show default \
        | awk '/default/ {print $5; exit}')

    [[ -z "$INTERFAZ" ]] && {
        echo -e "${ROJO}No se detectó interfaz activa${RESET}"
        exit 1
    }

    SUBRED=$(ip -o -f inet addr show "$INTERFAZ" \
        | awk '{print $4}' \
        | head -n1)

    echo -e "${VERDE}[+] Interfaz:${RESET} $INTERFAZ"
    echo -e "${VERDE}[+] Subred:${RESET} $SUBRED"
}

# ---------- MENÚ ----------
seleccionar_modo() {
    echo
    echo "1) Inventario rápido"
    echo "2) Servicios"
    echo "3) Seguridad doméstica"
    echo "4) Seguridad + TLS avanzado"
    echo

    read -rp "Seleccione modo: " MODO

    case "$MODO" in
        1|2|3|4) ;;
        *)
            echo "Modo inválido"
            exit 1
            ;;
    esac
}

# ---------- DESCUBRIMIENTO ----------
descubrir_hosts() {
    echo
    echo -e "${AZUL}[1/3] Descubriendo hosts...${RESET}"

    arp-scan \
        --interface="$INTERFAZ" \
        --localnet \
        --quiet > "$HOSTS_FILE"

    awk '/^[0-9]+\./ {print $1}' "$HOSTS_FILE"
}

# ---------- VALIDAR IP ----------
validar_ip() {
    # Expresión regular más estricta (0-255)
    [[ "$1" =~ ^(([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\.){3}([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$ ]]
}

# ---------- PERFIL NMAP ----------
ejecutar_scan() {
    local host="$1"
    local out="$RESULTS_DIR/$host"

    # NOTA: El 'echo' se eliminó de aquí para evitar que se pisen en la terminal

    case "$MODO" in
        1)
            nmap -Pn -sn "$host" -oN "${out}.txt" -oX "${out}.xml" >/dev/null 2>&1
        ;;
        2)
            nmap -Pn -sS -sV --top-ports 100 --host-timeout 5m "$host" -oN "${out}.txt" -oX "${out}.xml" >/dev/null 2>&1
        ;;
        3)
            nmap -Pn -sS -sV -O --top-ports 100 --script "safe" --host-timeout 5m "$host" -oN "${out}.txt" -oX "${out}.xml" >/dev/null 2>&1
        ;;
        4)
            nmap -Pn -sS -sV -O --top-ports 100 --script "safe,ssl-enum-ciphers" --host-timeout 10m "$host" -oN "${out}.txt" -oX "${out}.xml" >/dev/null 2>&1
        ;;
    esac
}

# ---------- ANALISIS ----------
analizar_hosts() {
    echo
    echo -e "${AZUL}[2/3] Analizando hosts...${RESET}"

    mapfile -t HOSTS < <(
        awk '/^[0-9]+\./ {print $1}' "$HOSTS_FILE"
    )

    [[ ${#HOSTS[@]} -eq 0 ]] && {
        echo "No se encontraron hosts."
        return
    }

    MAX_JOBS=4
    running=0

    for host in "${HOSTS[@]}"; do
        validar_ip "$host" || continue

        # El 'echo' se imprime de forma secuencial antes de lanzar el background job
        echo -e "${AMARILLO}Escaneando:${RESET} $host"

        (
            ejecutar_scan "$host"
        ) &

        ((running+=1))

        if (( running >= MAX_JOBS )); then
            wait -n
            ((running-=1))
        fi
    done

    wait
}

# ---------- MOSTRAR RESULTADOS ----------
mostrar_resultados() {
    echo
    echo -e "${AZUL}[3/3] Mostrando resultados de la auditoría...${RESET}"
    echo "======================================"
    
    # Comprobar si hay archivos de texto generados
    if ls "$RESULTS_DIR"/*.txt 1> /dev/null 2>&1; then
        for f in "$RESULTS_DIR"/*.txt; do
            [[ -f "$f" ]] || continue
            echo
            echo -e "${AMARILLO}--------------------------------------${RESET}"
            # basename "$f" .txt quita la extensión para mostrar solo la IP
            echo -e "${VERDE}Host: $(basename "$f" .txt)${RESET}"
            echo -e "${AMARILLO}--------------------------------------${RESET}"
            cat "$f"
        done
    else
        echo -e "${ROJO}No se generaron resultados para mostrar.${RESET}"
    fi
    echo "======================================"
}

# ---------- REPORTE ----------
guardar_reporte() {
    local fecha
    fecha=$(date +"%Y%m%d_%H%M")
    local reporte="$DESKTOP_PATH/Reporte_Red_${fecha}.txt"

    {
        echo "======================================"
        echo " AUDITORÍA DE RED DOMÉSTICA"
        echo "======================================"
        echo "Fecha: $(date)"
        echo "Interfaz: $INTERFAZ"
        echo "Subred: $SUBRED"
        echo

        echo "HOSTS DETECTADOS"
        echo "--------------------------------------"
        cat "$HOSTS_FILE"

        echo
        echo "RESULTADOS"
        echo "--------------------------------------"

        for f in "$RESULTS_DIR"/*.txt; do
            [[ -f "$f" ]] || continue
            echo
            echo "--------------------------------------"
            echo "Host: $(basename "$f" .txt)"
            echo "--------------------------------------"
            cat "$f"
        done
    } > "$reporte"

    # Se aplica el chown correcto usando el grupo real
    chown "$REAL_USER:$GRUPO_REAL" "$reporte" 2>/dev/null || true

    echo
    echo -e "${VERDE}[+] Reporte guardado en:${RESET} $reporte"
}

# ---------- PREGUNTAR GUARDADO ----------
preguntar_guardar() {
    echo
    read -rp "¿Deseas guardar estos resultados en un archivo de texto? (s/n): " RESPUESTA
    case "${RESPUESTA,,}" in # Convierte a minúscula
        s|si|y|yes)
            guardar_reporte
            ;;
        *)
            echo -e "${AZUL}Reporte descartado.${RESET}"
            ;;
    esac
}

# ---------- MAIN ----------
main() {
    mostrar_logo
    check_root
    check_tools
    detectar_red
    seleccionar_modo
    descubrir_hosts
    analizar_hosts
    
    # Nuevo flujo de finalización
    mostrar_resultados
    preguntar_guardar

    echo
    echo -e "${VERDE}Auditoría finalizada.${RESET}"
}

main
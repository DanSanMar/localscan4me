#!/bin/bash

# --- COLORES Y ESTÉTICA ---
export TERM=xterm-256color
BLANCO="\e[1;37m"
AZUL="\e[1;36m"
AMARILLO="\e[1;33m"
ROJO="\e[1;31m"
VERDE="\e[1;32m"
RESET="\e[0m"

# --- CONFIGURACIÓN DE RUTAS ---
# Detectamos el usuario real si se ejecuta con sudo
REAL_USER=$(logname 2>/dev/null || echo $USER)
DESKTOP_PATH="/home/$REAL_USER/Desktop"
[ ! -d "$DESKTOP_PATH" ] && DESKTOP_PATH="/home/$REAL_USER/Escritorio"

# --- FUNCIONES DE APOYO ---

function check_sudo() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${ROJO}Error: Este script requiere privilegios de superusuario.${RESET}"
        echo -e "${AZUL}Por favor, ejecútalo con: ${BLANCO}sudo $0${RESET}"
        exit 1
    fi
}

function mostrar_logo() {
    clear
    echo -e "${AZUL}"
    echo "  █████  ██      ██      ██   ██ ███    ███ ███████ "
    echo " ██   ██ ██      ██      ██   ██ ████  ████ ██      "
    echo " ███████ ██      ██      ███████ ██ ████ ██ █████   "
    echo " ██   ██ ██      ██           ██ ██  ██  ██ ██      "
    echo " ██   ██ ███████ ███████      ██ ██      ██ ███████ "
    echo -e "${BLANCO}  Versión 1.3 - lscan4me ${RESET}"
    echo -e "${AZUL}  --------------------------------------------------${RESET}"
    echo -e "${AMARILLO}  Herramienta automática para redes domésticas.${RESET}"
    echo -e "${AMARILLO}  Usa esta herramienta solo en tu red y con autorización.${RESET}\n"
}

function comprobar_herramientas() {
    local herramientas=(arp-scan nmap)
    for herramienta in "${herramientas[@]}"; do
        if ! command -v "$herramienta" >/dev/null 2>&1; then
            echo -e "${ROJO}Falta la herramienta: $herramienta${RESET}"
            echo -e "${AZUL}Instálala con: ${BLANCO}sudo apt install nmap arp-scan -y${RESET}"
            exit 1
        fi
    done
}

function detectar_red_hogar() {
    INTERFAZ=$(ip route get 1.1.1.1 2>/dev/null | awk '{print $5; exit}')
    SUBRED=$(ip route | awk -v iface="$INTERFAZ" '$1 !~ /^default/ && $5==iface {print $1; exit}')

    if [[ -z "$INTERFAZ" || -z "$SUBRED" ]]; then
        echo -e "${ROJO}No se pudo detectar la red local.${RESET}"
        exit 1
    fi

    echo -e "${VERDE}Interfaz activa:${BLANCO} $INTERFAZ${RESET}"
    echo -e "${VERDE}Red local detectada:${BLANCO} $SUBRED${RESET}"
}

function descubrir_hosts() {
    echo -e "\n${AZUL}[1/3] Descubriendo hosts activos en tu red doméstica...${RESET}"
    arp-scan --localnet -I "$INTERFAZ" --quiet 2>/tmp/scan_hosts.txt || true
    cat /tmp/scan_hosts.txt
}

function analizar_hosts() {
    echo -e "\n${AZUL}[2/3] Escaneando servicios y vulnerabilidades conocidas...${RESET}"
    local hosts
    hosts=$(awk 'NR>1 {print $1}' /tmp/scan_hosts.txt 2>/dev/null | grep -E '^[0-9.]+' || true)

    if [[ -z "$hosts" ]]; then
        echo -e "${AMARILLO}No se detectaron hosts activos.${RESET}"
        return
    fi

    for host in $hosts; do
        echo -e "\n${BLANCO}Analizando:${RESET} $host"
        nmap -Pn -sV --top-ports 50 --script vuln "$host" 2>/tmp/scan_host_$host.txt || true
        cat /tmp/scan_host_$host.txt
    done
}

function guardar_reporte() {
    local fecha
    local ruta
    fecha=$(date +"%Y%m%d_%H%M")
    ruta="$DESKTOP_PATH/Auditoria_Hogar_${fecha}.txt"

    {
        echo "--- AUDITORÍA HOME SCAN ---"
        echo "Fecha: $(date)"
        echo "Interfaz: $INTERFAZ"
        echo "Subred: $SUBRED"
        echo ""
        echo "[DESCUBRIMIENTO DE HOSTS]"
        cat /tmp/scan_hosts.txt 2>/dev/null
        echo ""
        echo "[ANÁLISIS DE VULNERABILIDADES]"
        for f in /tmp/scan_host_*.txt; do
            [ -f "$f" ] && cat "$f"
        done
    } > "$ruta"

    chown "$REAL_USER:$REAL_USER" "$ruta" 2>/dev/null || true
    echo -e "\n${VERDE}Reporte guardado en:${BLANCO} $ruta${RESET}"
}

function escaneo_automatico_hogar() {
    mostrar_logo
    comprobar_herramientas
    detectar_red_hogar
    descubrir_hosts
    analizar_hosts
    guardar_reporte
    echo -e "\n${AZUL}Escaneo finalizado. Revisa el archivo generado en tu escritorio.${RESET}"
}

# --- INICIO ---
check_sudo
escaneo_automatico_hogar
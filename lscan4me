#!/usr/bin/env bash

# ==========================================================
# Local Network Security Audit (Home Edition)
# Versión 5.0 - FZF Interactive Edition
# Uso exclusivo en redes propias o autorizadas
# ==========================================================

set -Eeuo pipefail
IFS=$'\n\t'
umask 077

# ---------- COLORES ----------
export TERM=xterm-256color

BLANCO="\e[1;37m"
AZUL="\e[1;36m"
AMARILLO="\e[1;33m"
ROJO="\e[1;31m"
VERDE="\e[1;32m"
RESET="\e[0m"

# ---------- USUARIO Y RUTAS ----------
REAL_USER=$(logname 2>/dev/null || echo "${SUDO_USER:-$USER}")
GRUPO_REAL=$(id -gn "$REAL_USER")

if command -v xdg-user-dir >/dev/null 2>&1; then
    DESKTOP_PATH=$(sudo -u "$REAL_USER" xdg-user-dir DESKTOP)
else
    DESKTOP_PATH="/home/$REAL_USER/Desktop"
    [[ ! -d "$DESKTOP_PATH" ]] && DESKTOP_PATH="/home/$REAL_USER/Escritorio"
fi

# ---------- TEMPORALES ----------
WORKDIR=$(mktemp -d /tmp/netaudit_XXXXXX)
chmod 700 "$WORKDIR"

HOSTS_FILE="$WORKDIR/hosts_cache.txt"
RESULTS_DIR="$WORKDIR/results"
mkdir -p "$RESULTS_DIR"

# ---------- LIMPIEZA ----------
cleanup() {
    [[ -d "$WORKDIR" ]] && rm -rf "$WORKDIR"
}
trap cleanup EXIT INT TERM

# ---------- LOGO ----------
mostrar_logo() {
    clear
    echo -e "${AZUL}"
    echo "  █████  ██      ██      ██    ██ ███    ███ ███████ "
    echo " ██   ██ ██      ██      ██    ██ ████  ████ ██      "
    echo " ███████ ██      ██      ███████ ██ ████ ██ █████    "
    echo " ██   ██ ██      ██           ██ ██  ██  ██ ██      "
    echo " ██   ██ ███████ ███████     ██ ██      ██ ███████ "
    echo -e "${BLANCO}   Versión 5.0 - Motor FZF Inteligente ${RESET}"
    echo -e "${AZUL}  --------------------------------------------------${RESET}"
    echo -e "${AMARILLO}   Uso exclusivo para redes autorizadas y auditorías internas.${RESET}\n"
}

# ---------- VALIDACIONES ----------
check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${ROJO}Debe ejecutarse como root:${RESET} sudo $0"
        exit 1
    fi
}

check_tools() {
    local tools=(arp-scan nmap ip awk sed grep mktemp fzf)
    for t in "${tools[@]}"; do
        if ! command -v "$t" >/dev/null 2>&1; then
            echo -e "${ROJO}Falta herramienta requerida:${RESET} $t"
            echo -e "${AMARILLO}Puedes instalarla con:${RESET} apt install $t"
            exit 1
        fi
    done
}

# ---------- DETECTAR RED ----------
detectar_red() {
    INTERFAZ=$(ip route show default | awk '/default/ {print $5; exit}')
    [[ -z "$INTERFAZ" ]] && { echo -e "${ROJO}No se detectó interfaz activa${RESET}"; exit 1; }
    SUBRED=$(ip -o -f inet addr show "$INTERFAZ" | awk '{print $4}' | head -n1)
    
    echo -e "${VERDE}[+] Interfaz activa:${RESET} $INTERFAZ"
    echo -e "${VERDE}[+] Subred detectada:${RESET} $SUBRED"
}

# ---------- RECONOCIMIENTO ÚNICO (PASO 1) ----------
reconocimiento_inicial() {
    echo
    echo -e "${AZUL}[i] Realizando mapeo inicial de la red...${RESET}"
    arp-scan --interface="$INTERFAZ" --localnet --quiet > "$HOSTS_FILE"
    
    # Validar que encontramos algo
    if ! grep -q '^[0-9]' "$HOSTS_FILE"; then
        echo -e "${ROJO}[!] No se encontraron hosts activos en la subred.${RESET}"
        exit 1
    fi
}

# ---------- SELECCIONAR OBJETIVO (FZF) ----------
seleccionar_host() {
    mostrar_logo
    echo -e "${AZUL}Seleccione el dispositivo a analizar (Use las flechas o escriba para filtrar):${RESET}"
    echo "----------------------------------------------------------------"
    
    # Preparamos la lista para FZF filtrando solo líneas con IPs válidas
    local seleccion
    seleccion=$(awk '/^[0-9]+\./ {print $1 " | " substr($0, index($0,$2))}' "$HOSTS_FILE" \
                | fzf --header="[ESC] Salir | Seleccione un Host" --ansi --height=40% --border)
    
    if [[ -z "$seleccion" ]]; then
        echo -e "${AMARILLO}Saliendo del auditor...${RESET}"
        exit 0
    fi

    # Extraemos solo la IP (lo que está antes del pipe)
    TARGET_IP=$(echo "$seleccion" | awk -F'|' '{print $1}' | tr -d '[:space:]')
}

# ---------- SELECCIONAR MODO DE ESCANEO (FZF) ----------
seleccionar_modo_scan() {
    echo
    echo -e "${AZUL}Seleccione el perfil de análisis para${RESET} ${VERDE}$TARGET_IP${RESET}:"
    echo "----------------------------------------------------------------"

    local opciones=(
        "1. Inspección Rápida (Ping Scan -sn)"
        "2. Investigación de Servicios (Top 100 Puertos + Versiones -sV)"
        "3. Seguridad Doméstica (Top 100 + Scripts Seguros + OS -O)"
        "4. Auditoría TLS Avanzada (Cifrados SSL/TLS exhaustivos)"
        "5. Volver a la lista de IPs"
    )

    local eleccion
    eleccion=$(printf "%s\n" "${opciones[@]}" | fzf --header="Seleccione Perfil Nmap" --height=30% --border)

    case "$eleccion" in
        *1.*) MODO=1 ;;
        *2.*) MODO=2 ;;
        *3.*) MODO=3 ;;
        *4.*) MODO=4 ;;
        *) return 1 ;; # Rompe y vuelve a la lista de IPs
    esac
    return 0
}

# ---------- LANZAR NMAP EN VIVO ----------
ejecutar_scan() {
    echo
    echo -e "${AMARILLO}==================================================${RESET}"
    echo -e "${VERDE} AUDITANDO TARGET: ${BLANCO}$TARGET_IP${RESET}"
    echo -e "${AMARILLO}==================================================${RESET}"
    
    local out="$RESULTS_DIR/$TARGET_IP"

    case "$MODO" in
        1) nmap -Pn -sn "$TARGET_IP" -oN "${out}.txt" ;;
        2) nmap -Pn -sS -sV --top-ports 100 --host-timeout 5m "$TARGET_IP" -oN "${out}.txt" ;;
        3) nmap -Pn -sS -sV -O --top-ports 100 --script "safe" --host-timeout 5m "$TARGET_IP" -oN "${out}.txt" ;;
        4) nmap -Pn -sS -sV -O --top-ports 100 --script "safe,ssl-enum-ciphers" --host-timeout 10m "$TARGET_IP" -oN "${out}.txt" ;;
    esac
}

# ---------- GUARDAR REPORTE INDIVIDUAL ----------
guardar_reporte() {
    local fecha
    fecha=$(date +"%Y%m%d_%H%M")
    local reporte="$DESKTOP_PATH/Reporte_${TARGET_IP}_${fecha}.txt"
    local source_file="$RESULTS_DIR/${TARGET_IP}.txt"

    if [[ -f "$source_file" ]]; then
        {
            echo "=================================================="
            echo " REPORTE DE AUDITORÍA INDIVIDUAL"
            echo "=================================================="
            echo "Objetivo: $TARGET_IP"
            echo "Fecha:    $(date)"
            echo "Subred:   $SUBRED"
            echo "--------------------------------------------------"
            cat "$source_file"
        } > "$reporte"
        
        chown "$REAL_USER:$GRUPO_REAL" "$reporte" 2>/dev/null || true
        echo -e "${VERDE}[+] Reporte guardado en:${RESET} $reporte"
    fi
}

preguntar_guardar() {
    echo
    read -rp "¿Deseas exportar el resultado de $TARGET_IP a tu Escritorio? (s/n): " RESPUESTA
    case "${RESPUESTA,,}" in
        s|si|y|yes) guardar_reporte ;;
        *) echo -e "${AZUL}Resultado de sesión descartado.${RESET}" ;;
    esac
}

# ---------- BUCLE PRINCIPAL ----------
main() {
    mostrar_logo
    detectar_red
    
    # PASO ÚNICO: Escaneo de red inicial
    reconocimiento_inicial
    
    # BUCLE INFINITO: Mantiene la lista de IPs fijas en memoria sin repetir arp-scan
    while true; do
        # 1. Elige IP desde la caché
        seleccionar_host
        
        # 2. Elige modo de escaneo (Si elige volver, salta al paso 1)
        if ! seleccionar_modo_scan; then
            continue
        fi
        
        # 3. Ejecuta Nmap en vivo
        ejecutar_scan
        
        # 4. Ofrece guardar los resultados
        preguntar_guardar
        
        echo
        echo -e "${AMARILLO}Presione [ENTER] para regresar a la lista de hosts...${RESET}"
        read -r
    done
}

# Inicialización obligatoria como Root y herramientas
check_root
check_tools
main
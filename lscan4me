#!/usr/bin/env bash

# ==========================================================
# Local Network Security Audit (Home Edition)
# Versión 5.5 - FZF Interactive & Device Identification
# Uso exclusivo en redes propias o autorizadas
# ==========================================================

set -Eeuo pipefail
IFS=$'\n\t'
umask 077

# ---------- COLORES ----------
export TERM=xterm-256color

BLANCO="\e[1;37m"
AZUL="\e[1;36m"
AMARILLO="\e[1;33m"
ROJO="\e[1;31m"
VERDE="\e[1;32m"
RESET="\e[0m"

# ---------- USUARIO Y RUTAS ----------
REAL_USER=$(logname 2>/dev/null || echo "${SUDO_USER:-$USER}")
GRUPO_REAL=$(id -gn "$REAL_USER")

if command -v xdg-user-dir >/dev/null 2>&1; then
    DESKTOP_PATH=$(sudo -u "$REAL_USER" xdg-user-dir DESKTOP)
else
    DESKTOP_PATH="/home/$REAL_USER/Desktop"
    [[ ! -d "$DESKTOP_PATH" ]] && DESKTOP_PATH="/home/$REAL_USER/Escritorio"
fi

# ---------- TEMPORALES ----------
WORKDIR=$(mktemp -d /tmp/netaudit_XXXXXX)
chmod 700 "$WORKDIR"

HOSTS_FILE="$WORKDIR/hosts_cache.txt"
RESULTS_DIR="$WORKDIR/results"
mkdir -p "$RESULTS_DIR"

# ---------- LIMPIEZA ----------
cleanup() {
    [[ -d "$WORKDIR" ]] && rm -rf "$WORKDIR"
}
trap cleanup EXIT INT TERM

# ---------- LOGO ----------
mostrar_logo() {
    clear
    echo -e "${AZUL}"
    echo "  █████  ██      ██      ██   ██ ███    ███ ███████ "
    echo " ██   ██ ██      ██      ██   ██ ████  ████ ██      "
    echo " ███████ ██      ██      ███████ ██ ████ ██ █████    "
    echo " ██   ██ ██      ██           ██ ██  ██  ██ ██      "
    echo " ██   ██ ███████ ███████      ██ ██      ██ ███████ "
    echo -e "${BLANCO}     Versión 5.5 - Identificación Inteligente ${RESET}"
    echo -e "${AZUL}  ------------------------------------------------------------${RESET}"
    echo -e "${AMARILLO}   Uso exclusivo para redes autorizadas y auditorías internas.${RESET}\n"
}
# ---------- VALIDACIONES ----------
check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${ROJO}Debe ejecutarse como root:${RESET} sudo $0"
        exit 1
    fi
}

check_tools() {
    local tools=(arp-scan nmap ip awk sed grep mktemp fzf)
    for t in "${tools[@]}"; do
        if ! command -v "$t" >/dev/null 2>&1; then
            echo -e "${ROJO}Falta herramienta requerida:${RESET} $t"
            exit 1
        fi
    done
}

# ---------- DETECTAR RED ----------
detectar_red() {
    INTERFAZ=$(ip route show default | awk '/default/ {print $5; exit}')
    [[ -z "$INTERFAZ" ]] && { echo -e "${ROJO}No se detectó interfaz activa${RESET}"; exit 1; }
    SUBRED=$(ip -o -f inet addr show "$INTERFAZ" | awk '{print $4}' | head -n1)
    
    echo -e "${VERDE}[+] Interfaz activa:${RESET} $INTERFAZ"
    echo -e "${VERDE}[+] Subred detectada:${RESET} $SUBRED"
}

# ---------- RECONOCIMIENTO ÚNICO ----------
reconocimiento_inicial() {
    echo
    echo -e "${AMARILLO}┌────────────────────────────────────── ──────────────────┐${RESET}"
    echo -e "${AMARILLO}${RESET}  ${AZUL}🔍 [1/2] ESCANEANDO LA RED LOCAL POR PRIMERA VEZ...${RESET}   ${AMARILLO}${RESET}"
    echo -e "${AMARILLO}${RESET}  ${BLANCO}Por favor, espera. Localizando dispositivos activos...${RESET} ${AMARILLO}${RESET}"
    echo -e "${AMARILLO}└────────────────────────────────────────────────────────┘${RESET}"
    echo
    
    arp-scan --interface="$INTERFAZ" --localnet --quiet > "$HOSTS_FILE"
    
    if ! grep -q '^[0-9]' "$HOSTS_FILE"; then
        echo -e "${ROJO}[!] No se encontraron hosts activos en la subred.${RESET}"
        exit 1
    fi
}

# ---------- SELECCIONAR OBJETIVO (FZF) ----------
seleccionar_host() {
    mostrar_logo
    echo -e "${AZUL}Seleccione el dispositivo a analizar:${RESET}"
    echo "----------------------------------------------------------------"
    
    local seleccion
    seleccion=$(awk '/^[0-9]+\./ {print $1 " | " substr($0, index($0,$2))}' "$HOSTS_FILE" \
                | fzf --header="[ESC] Salir | Seleccione un Host" --layout=reverse --no-sort --ansi --height=40% --border)
    if [[ -z "$seleccion" ]]; then
        echo -e "${AMARILLO}Saliendo del auditor...${RESET}"
        exit 0
    fi

    TARGET_IP=$(echo "$seleccion" | awk -F'|' '{print $1}' | tr -d '[:space:]')
    # Extraemos los datos de la MAC y fabricante recolectados por arp-scan
    TARGET_VENDOR=$(echo "$seleccion" | awk -F'|' '{print $2}' | sed 's/^[ \t]*//')
}

# ---------- SELECCIONAR MODO DE ESCANEO ----------
seleccionar_modo_scan() {
    echo
    echo -e "${AZUL}Seleccione el perfil de análisis para${RESET} ${VERDE}$TARGET_IP${RESET}:"
    echo "----------------------------------------------------------------"

    local opciones=(
        "1. Identificación Pasiva e Identidad"
        "2. Investigación de Servicios (Top 100 Puertos + Versiones -sV)"
        "3. Seguridad Doméstica (Top 100 + Scripts Seguros + OS -O)"
        "4. Auditoría TLS Avanzada (Cifrados SSL/TLS exhaustivos)"
        "5. Volver a la lista de IPs"
    )

    local eleccion
    eleccion=$(printf "%s\n" "${opciones[@]}" | fzf --header="Seleccione Perfil Nmap" --layout=reverse --no-sort --height=30% --border)

    case "$eleccion" in
        *1.*) MODO=1 ;;
        *2.*) MODO=2 ;;
        *3.*) MODO=3 ;;
        *4.*) MODO=4 ;;
        *) return 1 ;;
    esac
    return 0
}

u
# ---------- LANZAR SCAN ----------
ejecutar_scan() {
    echo
    echo -e "${AMARILLO}┌────────────────────────────────────────────────────────┐${RESET}"
    echo -e "${AMARILLO}${RESET}  ${VERDE}🚀 AUDITORÍA EN PROCESO EN TIEMPO REAL${RESET}                 ${AMARILLO}${RESET}"
    echo -e "${AMARILLO}${RESET}  ${AZUL}Objetivo:${RESET} ${BLANCO}$TARGET_IP${RESET}                               ${AMARILLO}${RESET}"
    echo -e "${AMARILLO}${RESET}  ${AMARILLO}Nota:${RESET} ${BLANCO}Nmap reportará su estado en pantalla en vivo.${RESET}    ${AMARILLO}${RESET}"
    echo -e "${AMARILLO}└────────────────────────────────────────────────────────┘${RESET}"
    echo
    
    local out="$RESULTS_DIR/$TARGET_IP"

    case "$MODO" in
        1)
            echo -e "${AZUL}[i] Iniciando Identificación Inteligente de Dispositivo...${RESET}"
            echo -e "${VERDE}Fabricante de Tarjeta (ARP):${RESET} $TARGET_VENDOR"
            echo "--------------------------------------------------"
            
            # Guardamos la cabecera en el archivo temporal
            echo "==================================================" > "${out}.txt"
            echo "REPORTE DE IDENTIFICACIÓN: $TARGET_IP" >> "${out}.txt"
            echo "Fabricante de Tarjeta (ARP): $TARGET_VENDOR" >> "${out}.txt"
            echo "==================================================" >> "${out}.txt"
            
            # NUEVA LISTA DE PUERTOS AMPLIADA Y RÁPIDA:
            # Añadimos 135,139,445 (Samba/Windows) y 5353 (mDNS de Apple/Alexa/Google)
            local nmap_raw
            nmap_raw=$(nmap -Pn -sS -sV -p 80,135,139,445,443,5353,5357,62078 --script="nbstat,smb-os-discovery" "$TARGET_IP" 2>/dev/null)
            
            # Guardamos la salida bruta en el archivo de texto para el reporte final
            echo "$nmap_raw" >> "${out}.txt"
            
            # --- MOTOR DE CLASIFICACIÓN LOGICA ---
            local tipo_predicho="Desconocido / Genérico (Posible Firewall Activo)"
            local vendor_lower
            vendor_lower=$(echo "$TARGET_VENDOR" | tr '[:upper:]' '[:lower:]')
            
            # 1. Detección de Altavoces Inteligentes / IoT asistentes
            if [[ "$vendor_lower" =~ "amazon" ]] || [[ "$nmap_raw" =~ "Amazon" ]]; then
                tipo_predicho="Altavoz Inteligente / Dispositivo Echo Alexa"
            elif [[ "$vendor_lower" =~ "google" ]] || [[ "$nmap_raw" =~ "Google" ]] || [[ "$nmap_raw" =~ "Chromecast" ]]; then
                tipo_predicho="Asistente Google Home / Chromecast"
            
            # 2. Detección de Enchufes, Bombillas e IoT Doméstico
            elif [[ "$vendor_lower" =~ "tuya" ]] || [[ "$vendor_lower" =~ "espressif" ]] || [[ "$vendor_lower" =~ "tp-link" ]] || [[ "$vendor_lower" =~ "sonoff" ]] || [[ "$vendor_lower" =~ "xiaomi" ]] || [[ "$vendor_lower" =~ "yeelight" ]]; then
                tipo_predicho="Dispositivo IoT Doméstico (Enchufe inteligente / Bombilla / Domótica)"
            
            # 3. Detección de Teléfonos Móviles / Tablets
            elif [[ "$vendor_lower" =~ "apple" ]] && echo "$nmap_raw" | grep -q "62078"; then
                tipo_predicho="Dispositivo Apple (iPhone o iPad)"
            elif [[ "$vendor_lower" =~ "huawei" ]] || [[ "$vendor_lower" =~ "samsung" ]] || [[ "$vendor_lower" =~ "oppo" ]] || [[ "$vendor_lower" =~ "xiaomi communications" ]]; then
                tipo_predicho="Teléfono Móvil / Smartphone Android"
            
            # 4. Detección de Ordenadores / Servidores
            elif echo "$nmap_raw" | grep -iqE "windows|microsoft|workgroup|netbios"; then
                tipo_predicho="Ordenador Personal (PC con Windows)"
            elif echo "$nmap_raw" | grep -qE "135/|139/|445/|5357/"; then
                tipo_predicho="Ordenador Personal / Servidor Windows (Servicios de Red Activos)"
            elif [[ "$vendor_lower" =~ "intel" ]] || [[ "$vendor_lower" =~ "asustek" ]] || [[ "$vendor_lower" =~ "gigabyte" ]] || [[ "$vendor_lower" =~ "msi" ]]; then
                tipo_predicho="Ordenador de Sobremesa / Portátil (PC)"
            fi
            
            # --- MOSTRAR RESULTADOS PREDICCION ---
            echo -e "${AMARILLO}🔍 RESULTADO DEL ANÁLISIS AUTOMÁTICO:${RESET}"
            echo -e "--------------------------------------------------"
            echo -e "${VERDE}[+] TIPO DE DISPOSITIVO:${RESET} ${BLANCO}$tipo_predicho${RESET}"
            
            # Extraemos y mostramos el nombre del equipo si NetBIOS o SMB lo capturaron
            local netbios_name
            netbios_name=$(echo "$nmap_raw" | awk '/NetBIOS computer name/ {print $5}' | tr -d ',\r')
            if [[ -n "$netbios_name" ]]; then
                echo -e "${VERDE}[+] NOMBRE DEL EQUIPO:${RESET} ${BLANCO}$netbios_name${RESET}"
                echo "Nombre de red detectado: $netbios_name" >> "${out}.txt"
            fi
            echo -e "--------------------------------------------------"
            echo "Tipo de dispositivo predicho: $tipo_predicho" >> "${out}.txt"
            
            # --- CONTROL DE DETALLES TÉCNICOS ---
            echo
            echo -e "${AZUL}Detalles técnicos del escaneo rápido:${RESET}"
            
            # Mostramos la latencia del Host
            echo "$nmap_raw" | grep "Host is up" || true
            
            # Extraemos las líneas de los puertos que estén estrictamente open o filtered
            local lineas_puertos
            lineas_puertos=$(echo "$nmap_raw" | grep -E "^[0-9]+/tcp|^[0-9]+/udp" || true)
            
            if [[ -n "$lineas_puertos" ]]; then
                echo -e "${BLANCO}PORT      STATE    SERVICE    VERSION${RESET}"
                echo "$lineas_puertos"
            else
                echo -e "${ROJO}[!] Todos los puertos tácticos están cerrados o invisibles (Firewall estricto).${RESET}"
            fi
            
            # Si el script de NetBIOS obtuvo respuesta, te lo pinta abajo de forma limpia
            echo "$nmap_raw" | grep -E "Host script results:|\|_nbstat:" -A 2 || true
        ;;
        2) 
            # --stats-every 5s le obliga a Nmap a imprimir su progreso cada 5 segundos en tu pantalla
            nmap -Pn -sS -sV --top-ports 100 --stats-every 5s --host-timeout 5m "$TARGET_IP" | tee -a "${out}.txt"
        ;;
        3) 
            nmap -Pn -sS -sV -O --top-ports 100 --script "safe" --stats-every 5s --host-timeout 5m "$TARGET_IP" | tee -a "${out}.txt"
        ;;
        4) 
            nmap -Pn -sS -sV -O --top-ports 100 --script "safe,ssl-enum-ciphers" --stats-every 5s --host-timeout 10m "$TARGET_IP" | tee -a "${out}.txt" 
        ;;
    esac
}

# ---------- GUARDAR REPORTE INDIVIDUAL ----------
guardar_reporte() {
    local fecha
    fecha=$(date +"%Y%m%d_%H%M")
    local reporte="$DESKTOP_PATH/Reporte_${TARGET_IP}_${fecha}.txt"
    local source_file="$RESULTS_DIR/${TARGET_IP}.txt"

    if [[ -f "$source_file" ]]; then
        {
            echo "=================================================="
            echo " REPORTE DE RECONOCIMIENTO DE DISPOSITIVO"
            echo "=================================================="
            echo "Objetivo: $TARGET_IP"
            echo "Fecha:    $(date)"
            echo "Subred:   $SUBRED"
            echo "--------------------------------------------------"
            cat "$source_file"
        } > "$reporte"
        
        chown "$REAL_USER:$GRUPO_REAL" "$reporte" 2>/dev/null || true
        echo -e "${VERDE}[+] Reporte guardado en:${RESET} $reporte"
    fi
}

preguntar_guardar() {
    echo
    read -rp "$(echo -e "${AMARILLO}¿Deseas exportar el resultado de $TARGET_IP a tu Escritorio? (s/n): ${RESET}")" RESPUESTA
    case "${RESPUESTA,,}" in
        s|si|y|yes) guardar_reporte ;;
        *) echo -e "${AZUL}Resultado de sesión descartado.${RESET}" ;;
    esac
}

# ---------- BUCLE PRINCIPAL ----------
main() {
    mostrar_logo
    detectar_red
    reconocimiento_inicial
    
    while true; do
        seleccionar_host
        if ! seleccionar_modo_scan; then
            continue
        fi
        ejecutar_scan
        preguntar_guardar
        
        echo
        echo -e "${AMARILLO}Presione [ENTER] para regresar a la lista de hosts...${RESET}"
        read -r
    done
}

check_root
check_tools
main